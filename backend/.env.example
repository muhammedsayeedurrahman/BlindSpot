# BlindSpot AI — Backend Environment Variables
# Copy this file to .env and fill in the values.

# AI Provider Keys (first available key wins — failover order below)
# 1. Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# 2. Groq (https://console.groq.com/keys) — 1K req/day free
GROQ_API_KEY=
# 3. Mistral (https://console.mistral.ai/api-keys) — 1B tokens/month free
MISTRAL_API_KEY=
# 4. OpenRouter (https://openrouter.ai/keys) — 29 free models
OPENROUTER_API_KEY=

# Supabase (optional — falls back to CSV/JSON without these)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Server port (default: 5000)
PORT=5000
