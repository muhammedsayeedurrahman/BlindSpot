# BlindSpot AI — Backend Environment Variables
# Copy this file to .env and fill in the values.

# Google Gemini API Key (free tier: 15 RPM for Gemini 2.0 Flash)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Server port (default: 5000)
PORT=5000
