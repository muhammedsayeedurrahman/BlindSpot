# BlindSpot AI — Frontend Environment Variables
# Copy this file to .env and fill in the values.

# API base URL (no trailing slash)
# Development: http://localhost:5000
# Production: leave empty (uses relative /api path on Vercel)
VITE_API_URL=

# Supabase (optional — app works without these, using localStorage only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
